{
  "name": "whatsapp-relay",
  "version": "0.1.0",
  "description": "Forward messages from one WhatsApp group to others (Baileys)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "groups": "tsx src/groups.ts",
    "build:win": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile dist/WhatsAppRelay.exe",
    "build:mac": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/WhatsAppRelay-mac",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/WhatsAppRelay-linux"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "@hapi/boom": "^10.0.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.4.0",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.9.3"
  }
}
