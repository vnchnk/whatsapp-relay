# --- Початковий конфіг (далі керується з веб-панелі, зберігається в auth/config.json) ---
# JID групи-джерела (звідки пересилати)
SOURCE_GROUP=
# JID-и груп-призначення через кому (куди пересилати)
DEST_GROUPS=

# Рандомна затримка між відправками (мс) — щоб не виглядало як спам-бот
MIN_DELAY_MS=5000
MAX_DELAY_MS=10000

# Де зберігати сесію WhatsApp (за замовч. ./auth)
AUTH_DIR=auth

# --- Веб-панель ---
PORT=8080
ADMIN_USER=admin
ADMIN_PASS=admin
SESSION_SECRET=change-me-to-a-random-string
